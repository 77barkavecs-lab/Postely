.fx{display:flex}.col{flex-direction:column}.ac{align-items:center}.jc{justify-content:center}.jb{justify-content:space-between}.gap16{gap:16px}
.page{background:#FAF7F2;color:#171C28;font-family:'Instrument Sans',system-ui,sans-serif;line-height:1.65;-webkit-font-smoothing:antialiased;font-size:16px}
.serif{font-family:'Playfair Display',Georgia,serif;font-weight:500;line-height:1.15;letter-spacing:-.01em}
