.flinks a{font-size:13px;color:rgba(246,242,235,.55);text-decoration:none;letter-spacing:.03em}
.price{font-family:'Playfair Display',serif;font-size:40px;line-height:1;margin:0}
.per{font-size:15px;color:#787d89;font-family:'Instrument Sans',sans-serif}
.lock{font-size:12.5px;letter-spacing:.08em;color:#5AA7E0;text-transform:uppercase;font-weight:600;margin-top:8px}
.feat{margin-top:28px;padding-top:24px;border-top:1px solid #EEEBE4;display:flex;flex-direction:column;gap:11px;flex:1}
