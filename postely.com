<body>
<div class="page">
<header class="sect tc" style="padding:130px 0 140px">
<div class="wrap fade vis">
<svg viewBox="0 0 40 34" width="40" height="34" aria-label="Postely" style="color:#171C28"><path d="M4 4v27h32V4M4 4l16 15L36 4" fill="none" stroke="currentColor" stroke-width="3" stroke-miterlimit="8"></path></svg>
<p class="track upper fw6 m0" style="font-size:15px;margin-top:14px">Postely</p>
<h1 class="serif hero-h" style="margin-top:34px">Never think about your mail again.</h1>
<p class="muted" style="font-size:18px;max-width:460px;margin:26px auto 0">A personal mail &amp; package concierge for one neighborhood in Santa Monica. Launching soon.</p>
<div style="margin-top:44px"><a href="#waitlist" class="btn">Join the founding list</a></div>
</div>
</header>
<figure style="margin:0">
<img class="slotfill" src="storefront.jpg" width="1122" height="1402" loading="lazy" alt="Postely mail concierge storefront in Santa Monica at dusk">
<figcaption class="tc muted ital" style="font-size:14px;letter-spacing:.06em;padding:22px 24px 0">Physical when you want it. Digital when you don't.</figcaption>
</figure>
<section class="ink sect tc" style="margin-top:88px">
<div class="wrap fade">
<p class="serif ital probline">The packages you can't be home for.</p>
<p class="serif ital probline">The junk you didn't ask for.</p>
<p class="serif ital probline">The returns you keep meaning to do.</p>
<hr class="hair" style="margin:38px auto">
<p class="serif" style="font-size:clamp(28px,3.6vw,38px);margin:0">Mail was never supposed to be your job.</p>
</div>
</section>
<section class="sect">
<div class="wrap tc fade">
<h2 class="track upper fs12 fw6 muted m0">How it works</h2>
<div class="fx col" style="gap:52px;margin-top:64px">
<div class="step"><span class="num">1</span><div><h3 class="serif m0" style="font-size:23px">Your mail comes to us.</h3><p class="muted" style="margin:8px 0 0;font-size:16px">A staffed Santa Monica address receives everything — letters, packages, every carrier.</p></div></div>
<div class="step"><span class="num">2</span><div><h3 class="serif m0" style="font-size:23px">You see it on your phone.</h3><p class="muted" style="margin:8px 0 0;font-size:16px">Every envelope scanned same-day. Tap to open, forward, or shred. Junk handled on your standing orders. Nothing is ever opened without your tap.</p></div></div>
<div class="step"><span class="num">3</span><div><h3 class="serif m0" style="font-size:23px">We come to you.</h3><p class="muted" style="margin:8px 0 0;font-size:16px">Packages delivered to your door in your window. Returns picked up, packed, and shipped — just text us.</p></div></div>
</div>
</div>
</section>
<section class="sect" style="padding-top:40px">
<div class="wrap tc fade" style="margin-bottom:60px">
<p class="track upper fs12 fw6 muted m0">Founding pricing</p>
<h2 class="serif sect-h" style="margin-top:18px">Three ways to never think <span class="nowrap">about it.</span></h2>
</div>
<div class="cards fade">
<div class="card">
<h3 class="tier">Postely Virtual</h3>
<p class="was">$29/mo</p>
<p class="price">$25<span class="per"> /mo</span></p>
<div class="feat">
<div class="fi">A real Santa Monica address</div>
<div class="fi">Every envelope scanned same-day</div>
<div class="fi">Unlimited envelope scanning · 15 full-content scans included (most members use far fewer)</div>
<div class="fi">Junk auto-shred on your rules</div>
<div class="fi">Mail forwarding — postage at cost</div>
<div class="fi">30-day storage</div>
</div>
</div>
<div class="card">
<h3 class="tier">Postely Business</h3>
<p class="was">$55/mo</p>
<p class="price">$45<span class="per"> /mo</span></p>
<div class="feat">
<div class="fi">Everything in Virtual — unlimited everything: scans, opens, forwards</div>
<div class="fi">Registered agent included</div>
<div class="fi">Government mail flagged urgently</div>
<div class="fi">Check deposit</div>
<div class="fi">Multiple names</div>
<div class="fi">Sender-level blocking</div>
<div class="fi">Notary access</div>
</div>
</div>
<div class="card flag">
<div class="badge">★ Founding 50 — limited</div>
<h3 class="tier">Postely Household</h3>
<p class="was">$179/mo</p>
<p class="price">$149<span class="per"> /mo</span></p>
<p class="lock">Locked for life</p>
<p class="muted" style="font-size:13.5px;margin:7px 0 0">Setup fee waived — Founding 50.</p>
<div class="feat">
<div class="fi">Everything in Business</div>
<div class="fi">All packages ship to us &amp; held safe</div>
<div class="fi">Scheduled home delivery in your window</div>
<div class="fi">Returns concierge — text us, we handle it</div>
<div class="fi">Full mail curation</div>
<div class="fi" style="margin-top:6px"><a href="/stop-porch-pirates-santa-monica" style="color:#171C28">Worried about porch pirates? What actually works →</a></div>
</div>
</div>
</div>
<div class="wrap tc fade" style="margin-top:44px">
<p class="muted" style="font-size:13.5px;margin:0 0 20px">Standard pricing at launch. Founding pricing locked for life.</p>
<p class="muted ital" style="font-size:15.5px;margin:0">Already rent a physical box in the neighborhood? Add the full digital layer — founding add-on $19/mo.</p>
<p class="fw6" style="font-size:15px;margin:26px 0 0;letter-spacing:.02em">Monthly billing. Cancel anytime. No minimums, no contracts, no fine print.</p>
</div>
</section>
<section class="letter sect">
<div class="fade" style="max-width:620px;margin:0 auto;padding:0 24px">
<h2 class="track upper fs12 fw6 muted m0 tc">A note from the founder</h2>
<div class="paper" style="margin-top:36px">
<p class="serif" style="font-size:22px;margin:0 0 24px">Dear neighbor,</p>
<p class="lbody">I'm Jared. I live a few blocks from the ocean, and like everyone in this neighborhood I was drowning in the same things — packages I couldn't be home for, junk I never asked for, returns I kept meaning to do.</p>
<p class="lbody" style="margin-top:20px">So I'm building the service I wanted: a mail and package concierge for our neighborhood. You won't see my face much online. You'll see it at your doorstep.</p>
<div class="fx ac jb" style="margin-top:36px">
<span style="font-family:'Caveat',cursive;font-size:34px;line-height:1">— Jared</span>
<svg viewBox="0 0 56 56" width="48" height="48" aria-hidden="true"><circle cx="28" cy="28" r="26" fill="#171C28"></circle><circle cx="28" cy="28" r="21.5" fill="none" stroke="#FAF7F2" stroke-width="1" stroke-dasharray="2.5 3"></circle><path d="M18 19v18h20V19M18 19l10 9.5L38 19" fill="none" stroke="#FAF7F2" stroke-width="1.8" stroke-miterlimit="8"></path></svg>
</div>
</div>
</div>
</section>
<section class="ink sect" id="waitlist">
<div class="wrap tc">
<div id="form-state">
<h2 class="serif sect-h">Reserve founding access.</h2>
<p class="dim" style="font-size:16.5px;max-width:440px;margin:20px auto 0">Free to join. No card, no commitment. Founding pricing locks for you when we launch.</p>
<form id="waitlist-form" style="max-width:440px;margin:56px auto 0" novalidate>
<div class="fgroup"><label class="lbl" for="p-name">Name</label><input class="inp" id="p-name" name="name" type="text" autocomplete="name"></div>
<div class="fgroup"><label class="lbl" for="p-email">Email</label><input class="inp" id="p-email" name="email" type="email" autocomplete="email"></div>
<div class="fgroup"><label class="lbl" for="p-hood">Neighborhood</label><div class="selwrap"><select class="inp" id="p-hood" name="neighborhood"><option value="" disabled selected>Select…</option><option>North of Montana</option><option>South of Montana</option><option>Elsewhere in Santa Monica</option><option>Outside Santa Monica</option></select><span class="caret">▼</span></div></div>
<div class="fgroup"><span class="lbl">I'm interested in</span>
<label class="chk"><input class="box" type="checkbox" name="interest" value="Virtual mailbox">Virtual mailbox</label>
<label class="chk"><input class="box" type="checkbox" name="interest" value="Business address">Business address</label>
<label class="chk"><input class="box" type="checkbox" name="interest" value="Household concierge">Household concierge (delivery + returns)</label>
</div>
<div class="fgroup hidden" id="zip-group"><label class="lbl" for="p-zip">Your neighborhood or zip</label><input class="inp" id="p-zip" name="zip" type="text"><p class="dim" style="font-size:13.5px;margin:10px 0 0;line-height:1.55">Drop your neighborhood or zip — you'll be first to know when Postely reaches you. (Our virtual mailbox and business address services will be available anywhere at launch.)</p></div>
<button class="btn w100" type="submit">Reserve founding access</button>
<p class="err" id="form-err">Please add your name and a valid email.</p>
</form>
</div>
<div id="success-state" class="hidden">
<div style="max-width:480px;margin:0 auto">
<svg viewBox="0 0 56 56" width="64" height="64" aria-hidden="true"><circle cx="28" cy="28" r="26" fill="#FAF7F2"></circle><circle cx="28" cy="28" r="21.5" fill="none" stroke="#171C28" stroke-width="1" stroke-dasharray="2.5 3"></circle><path d="M18 19v18h20V19M18 19l10 9.5L38 19" fill="none" stroke="#171C28" stroke-width="1.8" stroke-miterlimit="8"></path></svg>
<h2 class="serif" style="font-size:clamp(26px,3.4vw,34px);margin:32px 0 0">You're on the list.</h2>
<p class="dim" style="font-size:16.5px;margin:22px 0 0">We'll email you the moment doors open. Tell a neighbor: founding spots are capped.</p>
</div>
</div>
</div>
</section>
<section class="sect">
<div class="wrap fade">
<h2 class="track upper fs12 fw6 muted m0 tc">Questions, answered</h2>
<div style="margin-top:48px">
<div class="faq" style="border-top:none;padding-top:0"><h3 class="serif faq-q">What is a mail concierge?</h3><p class="faq-a">A staffed service that manages your mail and packages for you. Postely receives everything at a staffed Santa Monica address, scans every envelope to your phone the day it arrives, shreds junk on your standing orders, holds packages safe, and delivers to your door in your window.</p></div>
<div class="faq"><h3 class="serif faq-q">How does a virtual mailbox work?</h3><p class="faq-a">Your mail is addressed to a real Santa Monica street address instead of your home. Every envelope is photographed same-day and appears in your Postely feed — tap to have it opened and scanned, forwarded anywhere, or shredded. Junk is handled automatically on rules you set once.</p></div>
<div class="faq"><h3 class="serif faq-q">Is my mail opened without permission?</h3><p class="faq-a">Never. Envelopes are photographed from the outside only. Nothing is opened unless you tap to request a full-content scan, and shredding only happens on rules you set yourself.</p></div>
<div class="faq"><h3 class="serif faq-q">What areas do you serve?</h3><p class="faq-a">Home package delivery and returns pickup serve Santa Monica. Our <a href="/virtual-mailbox-santa-monica" style="color:inherit">virtual mailbox</a> and <a href="/business-address-santa-monica" style="color:inherit">business address</a> plans work from anywhere — your mail simply arrives at our Santa Monica address and you manage it from your phone.</p></div>
<div class="faq"><h3 class="serif faq-q">Can I get a Santa Monica business address remotely?</h3><p class="faq-a">Yes. Postely Business gives you a prestige Santa Monica street address usable on your website, LLC filings, and correspondence, with a <a href="/registered-agent-california" style="color:inherit">registered agent</a> included — wherever you actually live or work.</p></div>
</div>
</div>
</section>
<footer class="ink foot tc" style="padding:64px 24px;border-top:1px solid rgba(246,242,235,.1)">
<svg viewBox="0 0 40 34" width="28" height="24" style="color:rgba(246,242,235,.85)"><path d="M4 4v27h32V4M4 4l16 15L36 4" fill="none" stroke="currentColor" stroke-width="3" stroke-miterlimit="8"></path></svg>
<p class="track upper fw6 m0" style="font-size:12px;margin-top:10px;color:rgba(246,242,235,.85)">Postely</p>
<p class="dim" style="font-size:14px;margin:18px 0 0;letter-spacing:.04em">Postely — Santa Monica, CA</p>
<div class="fx ac jc gap16" style="margin-top:16px">
<a href="mailto:hello@getpostely.com" style="font-size:14px">hello@getpostely.com</a>
<a href="https://instagram.com/postely" aria-label="Instagram"><svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4.2"></circle><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"></circle></svg></a>
</div>
<nav class="flinks" aria-label="Services">
<a href="/business-address-santa-monica">Business address — Santa Monica</a>
<a href="/virtual-mailbox-santa-monica">Virtual mailbox — Santa Monica</a>
<a href="/registered-agent-california">Registered agent — California</a>
<a href="/package-receiving-santa-monica">Package receiving — Santa Monica</a>
<a href="/stop-porch-pirates-santa-monica">Stop porch pirates — Santa Monica</a>
</nav>
</footer>
</div>
<script>
// Swap in your real endpoint: a Google Apps Script web-app URL (doPost -> appends to a
// Google Sheet + MailApp.sendEmail notification) or a Tally webhook. Fields POSTed as JSON:
// { name, email, neighborhood, interests[], zip }
var WAITLIST_ENDPOINT = 'https://script.google.com/macros/s/PASTE_YOUR_DEPLOYMENT_ID/exec';

// Fade-ups on scroll
var io = new IntersectionObserver(function (entries) {
  entries.forEach(function (en) {
    if (en.isIntersecting) { en.target.classList.add('vis'); io.unobserve(en.target); }
  });
}, { threshold: 0.12 });
document.querySelectorAll('.fade:not(.vis)').forEach(function (el) { io.observe(el); });

// Waitlist form
var form = document.getElementById('waitlist-form');
var hood = document.getElementById('p-hood');
var zipGroup = document.getElementById('zip-group');
var errEl = document.getElementById('form-err');

function showSuccess() {
  document.getElementById('form-state').classList.add('hidden');
  document.getElementById('success-state').classList.remove('hidden');
}
try {
  var saved = JSON.parse(localStorage.getItem('postely_signup') || 'null');
  if (saved && saved.email) showSuccess();
} catch (e) {}

hood.addEventListener('change', function () {
  zipGroup.classList.toggle('hidden', hood.value !== 'Outside Santa Monica');
});

form.addEventListener('submit', function (e) {
  e.preventDefault();
  var name = document.getElementById('p-name').value.trim();
  var email = document.getElementById('p-email').value.trim();
  if (!name || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { errEl.style.display = 'block'; return; }
  errEl.style.display = 'none';
  var interests = Array.prototype.map.call(form.querySelectorAll('input[name="interest"]:checked'), function (c) { return c.value; });
  var entry = { name: name, email: email, neighborhood: hood.value, interests: interests, zip: document.getElementById('p-zip').value.trim() };
  try {
    fetch(WAITLIST_ENDPOINT, { method: 'POST', mode: 'no-cors', headers: { 'Content-Type': 'text/plain;charset=utf-8' }, body: JSON.stringify(entry) }).catch(function () {});
  } catch (e2) {}
  try { localStorage.setItem('postely_signup', JSON.stringify(entry)); } catch (e3) {}
  showSuccess();
});
</script>
</body>
</html>
