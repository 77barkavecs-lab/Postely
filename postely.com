.btn{display:inline-block;background:#5AA7E0;color:#fff;font-size:13px;letter-spacing:.16em;text-transform:uppercase;font-weight:600;padding:17px 36px;border-radius:2px;border:none;cursor:pointer;text-decoration:none;font-family:inherit;transition:opacity .25s}
.btn:hover{opacity:.88}
.hero-h{font-size:clamp(40px,6.5vw,68px);margin:0}
.sect-h{font-size:clamp(30px,4vw,42px);margin:0}
.probline{font-size:clamp(21px,2.6vw,27px);margin:0 0 14px;color:rgba(246,242,235,.78)}
.step{display:flex;gap:28px;align-items:baseline;text-align:left}
.num{font-family:'Playfair Display',serif;font-style:italic;font-size:22px;color:#5AA7E0;flex-shrink:0;width:28px}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;max-width:1120px;margin:0 auto;padding:0 24px;align-items:stretch}
.card{background:#fff;border:1px solid #E6E4DF;padding:44px 34px 38px;display:flex;flex-direction:column;text-align:left;box-sizing:border-box}
